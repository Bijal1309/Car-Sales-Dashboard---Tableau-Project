    <worksheet name='YTD Avg Price'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Car Sales Data)' name='federated.1xtf91h0xonxq614av81c1bimzzd' />
          </datasources>
          <datasource-dependencies datasource='federated.1xtf91h0xonxq614av81c1bimzzd'>
