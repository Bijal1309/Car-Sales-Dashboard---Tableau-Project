            <column caption='PYTD Cars Sold' datatype='integer' name='[YTD Cars Sold (copy)_195343647542276100]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT( IF &#13;&#10;YEAR([Date]) = {MAX(YEAR([Date]))} - 1&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
            </column>
            <column caption='PYTD Total Sales' datatype='integer' name='[YTD Total Sales (copy)_195343647513645057]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF &#13;&#10;YEAR ([Date]) = {fixed :MAX (YEAR([Date]))} - 1&#13;&#10;Then&#13;&#10;[Price ($)]&#13;&#10;END)' />
            </column>
