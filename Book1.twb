      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1xtf91h0xonxq614av81c1bimzzd].[pcto:usr:Calculation_195343647511896064:qk]&quot;' value='% of Total YTD Total Sales' />
        </aliases>
      </column>
      <column datatype='string' name='[Body Style]' role='dimension' type='nominal' />
      <column caption='YTD Total Sales' datatype='integer' default-format='c&quot;$&quot;#,##0,,.00M;-&quot;$&quot;#,##0,,.00M' name='[Calculation_195343647511896064]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF &#13;&#10;YEAR ([Date]) = {fixed :MAX (YEAR([Date]))}&#13;&#10;Then&#13;&#10;[Price ($)]&#13;&#10;END)' />
      </column>
      <column caption='YOY Sales Growth' datatype='real' name='[Calculation_195343647515774978]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_195343647511896064]-[YTD Total Sales (copy)_195343647513645057]) / [YTD Total Sales (copy)_195343647513645057]' />
      </column>
      <column caption='YTD Cars Sold' datatype='integer' default-format='c&quot;#&quot;#,##0,.00K;-&quot;#&quot;#,##0,.00K' name='[Calculation_195343647541805059]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF &#13;&#10;YEAR([Date]) = {MAX(YEAR([Date]))}&#13;&#10;THEN&#13;&#10;[Car_id]&#13;&#10;END)' />
      </column>
      <column caption='YOY Cars Sold Growth' datatype='real' default-format='p0.00%' name='[Calculation_195343647542362117]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_195343647541805059] - [YTD Cars Sold (copy)_195343647542276100]) / [YTD Cars Sold (copy)_195343647542276100]' />
      </column>
      <column caption='YTD Avg Price' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;-&quot;$&quot;#,##0,.00K' name='[Calculation_195343647544082438]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_195343647511896064] / [Calculation_195343647541805059]' />
      </column>
      <column caption='PYTD Avg Price' datatype='real' name='[Calculation_195343647544344583]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[YTD Total Sales (copy)_195343647513645057] / [YTD Cars Sold (copy)_195343647542276100]' />
      </column>
      <column caption='YOY Avg Growth' datatype='real' default-format='p0.00%' name='[Calculation_195343647544520712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_195343647544082438] - [Calculation_195343647544344583]) / [Calculation_195343647544344583]' />
      </column>
      <column caption='Min Date' datatype='date' name='[Calculation_2183964358346792967]' role='dimension' type='ordinal'>
